# Backend FastAPI Environment Variables

# Application Settings
APP_NAME="API de Riesgo Financiero"
APP_VERSION="1.0.0"
DEBUG=false

# Financial Data Settings
DEFAULT_START_DATE="2024-01-01"
DEFAULT_END_DATE="2026-04-08"
DEFAULT_CONFIDENCE_LEVEL=0.05
RISK_FREE_RATE=0.02

# Technical Analysis Settings
SMA_SHORT_WINDOW=20
SMA_LONG_WINDOW=50
RSI_WINDOW=14

# Volatility Settings
GARCH_P=1
GARCH_Q=1

# CORS Settings
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8502

# API Keys (if needed for external services)
# YAHOO_FINANCE_API_KEY=
# ALPHA_VANTAGE_API_KEY=